# Выбор модели (можно переопределить флагом --model):
#   qwen-7b | qwen-3b | gigachat | gigachat-max
LLM_MODEL=qwen-7b

# --- Локальные qwen через Ollama (qwen-7b / qwen-3b) ---
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- GigaChat (gigachat / gigachat-max) ---
# Authorization key из личного кабинета Sber (base64). Без него облачные модели не работают.
GIGACHAT_TOKEN=ваш_authorization_key_из_личного_кабинета_sber
# Область доступа: GIGACHAT_API_PERS (физлица) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
