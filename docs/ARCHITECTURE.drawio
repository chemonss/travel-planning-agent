<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="travel-agent-arch" name="LLM-driven architecture">
    <mxGraphModel dx="1100" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="user" value="Пользователь&#10;user_request + session_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="60" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="role" value="Адаптивная роль (runner)&#10;базовый system_prompt + контекст из памяти сессии" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="55" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="loop" value="LLM agent loop (qwen2.5:7b)&#10;tool-calling ReAct: рассуждение → действие →&#10;переплан при infeasible/over budget" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="260" height="100" as="geometry" />
        </mxCell>

        <mxCell id="tools" value="execute_tool (tools_spec)&#10;get_group_profile · search_flights/hotels/tours&#10;calculate_budget · retrieve_policy&#10;recall_memory · save_memory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="660" y="190" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="db" value="SQLite travelers.sqlite&#10;(read-only)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="700" y="360" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="docs" value="policy-документы&#10;data/documents/*.md (RAG)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="850" y="360" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="reflect" value="Рефлексия (критик)&#10;цель / бюджет / ограничения&#10;при проблеме → назад в цикл" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="320" y="360" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="validate" value="Валидация ID в БД&#10;(анти-галлюцинация — единственный жёсткий guard)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="320" y="480" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="mem" value="Память — цифровой двойник&#10;data/memory/&lt;session&gt;.json" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="160" height="90" as="geometry" />
        </mxCell>

        <mxCell id="out" value="AgentOutput (structured) + trace&#10;info|recommendation|clarification|escalation|rejection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="610" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="user" target="role"><mxGeometry relative="1" as="geometry" /></mxCell>
