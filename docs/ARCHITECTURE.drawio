        <mxCell id="e8" value="issue" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;dashed=1;" edge="1" parent="1" source="reflect" target="loop"><mxGeometry relative="1" as="geometry" /></mxCell>
